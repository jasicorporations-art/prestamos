# Supabase (obligatorio)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Prisma / Base de datos (Supabase Postgres + Railway)
# DATABASE_URL = pool de conexiones (usado por la app en producción/Railway)
# DIRECT_URL = conexión directa (solo para migraciones: npx prisma migrate)
DATABASE_URL=
DIRECT_URL=

# WhatsApp - Soporte al cliente (formato E.164)
# Ejemplo: +15558584209 (EE.UU.) o +18095551234
# Usado en: wa.me, botón de soporte, Footer, FloatingSupport, Navigation, AppShell
WHATSAPP_NUMBER=+15558584209
NEXT_PUBLIC_WHATSAPP_NUMBER=+15558584209

# Twilio - Recibos por WhatsApp (Edge Function send-whatsapp2)
# IMPORTANTE: Estos valores NO se leen desde aquí para enviar recibos.
# Debes configurarlos en: Supabase Dashboard → Project Settings → Edge Functions → Secrets
# Nombre del secret: TWILIO_MESSAGING_SERVICE_SID | Valor: SID del Messaging Service (empieza con MG...)
# También en Supabase Secrets: TWILIO_SID, TWILIO_TOKEN, TWILIO_NUMBER, TWILIO_CONTENT_SID_RECIBO (HX...)
# Referencia local (opcional, solo para documentación):
TWILIO_MESSAGING_SERVICE_SID=
